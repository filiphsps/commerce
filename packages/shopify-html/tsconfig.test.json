{
    "$schema": "https://json.schemastore.org/tsconfig",
    "extends": "./tsconfig.json",
    "compilerOptions": {
        "noEmit": true,
        "types": ["vitest/globals"]
    },
    "include": ["src/**/*.test.*", "vitest.setup.ts"],
    "exclude": [
        "**/node_modules",
        "**/dist",
        "**/.turbo",
        "**/storybook-static",
        "**/coverage",
        "**/build",
        "**/public"
    ]
}
