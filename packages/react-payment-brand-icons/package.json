{
    "$schema": "https://json.schemastore.org/package.json",
    "name": "react-payment-brand-icons",
    "version": "0.2.1",
    "publishConfig": {
        "access": "public"
    },
    "description": "Tree-shakeable React components for payment-method brand icons (Visa, Mastercard, Apple Pay, Swish, and 460+ more).",
    "private": false,
    "sideEffects": false,
    "type": "module",
    "types": "./dist/index.d.ts",
    "module": "./dist/index.ts",
    "exports": {
        ".": [
            "./src/index.ts",
            "./dist/index.js"
        ],
        "./icons/*": [
            "./src/generated/icons/*.tsx",
            "./dist/generated/icons/*.js"
        ],
        "./manifest": [
            "./src/generated/manifest.ts",
            "./dist/manifest.js"
        ]
    },
    "scripts": {
        "build": "pnpm generate && tsc && vite build",
        "clean": "rimraf -g dist coverage .turbo src/generated *.tsbuildinfo *.log node_modules",
        "dev": "tsx scripts/gallery.ts",
        "docs:gen": "tsx scripts/gallery.ts --docs docs/icons.mdx",
        "format:check": "biome check --write --unsafe .",
        "format:format": "biome format --write .",
        "format:lint": "biome lint --write .",
        "format": "pnpm format:lint & p1=$! ; pnpm format:format & p2=$! ; pnpm format:check & p3=$! ; wait $p1 && wait $p2 && wait $p3",
        "generate": "pnpm icons:gen && pnpm docs:gen",
        "icons:gen": "tsx scripts/generate.ts",
        "lint": "biome lint .",
        "svgs:prettify": "tsx scripts/prettify-source-svgs.ts",
        "test": "vitest run",
        "typecheck": "tsc -noEmit"
    },
    "files": [
        "dist",
        "README.md"
    ],
    "author": {
        "name": "Filiph Sandström",
        "email": "filfat@hotmail.se",
        "url": "https://github.com/filiphsps/"
    },
    "contributors": [
        {
            "name": "Filiph Sandström",
            "email": "filfat@hotmail.se",
            "url": "https://github.com/filiphsps/"
        }
    ],
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/filiphsps/commerce.git",
        "directory": "packages/react-payment-brand-icons"
    },
    "keywords": [
        "react",
        "payment",
        "icons",
        "svg",
        "visa",
        "mastercard",
        "shopify",
        "checkout"
    ],
    "bugs": {
        "url": "https://github.com/filiphsps/commerce/issues"
    },
    "homepage": "https://filiphsps.github.io/commerce/packages/ui/react-payment-brand-icons/icons/",
    "peerDependencies": {
        "react": ">=18",
        "react-dom": ">=18"
    },
    "devDependencies": {
        "@codecov/vite-plugin": "2.0.1",
        "@svgr/core": "8.1.0",
        "@svgr/plugin-jsx": "8.1.0",
        "@testing-library/react": "16.3.2",
        "@types/react": "19.2.17",
        "@types/react-dom": "19.2.3",
        "happy-dom": "20.10.3",
        "jsdom": "29.1.1",
        "react": "^19.2.7",
        "react-dom": "^19.2.7",
        "rimraf": "6.1.3",
        "svgo": "4.0.1",
        "svgson": "5.3.1",
        "tsx": "4.22.4",
        "typescript": "6.0.3",
        "vite": "8.0.16",
        "vitest": "4.1.8"
    }
}
