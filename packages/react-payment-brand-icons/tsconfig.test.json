{
    "$schema": "https://json.schemastore.org/tsconfig",
    "extends": ["./tsconfig.json", "../../tsconfig.test.json"],
    "compilerOptions": {
        "types": ["node", "vitest/globals"]
    },
    "include": [
        "./src/**/*.test.ts",
        "./src/**/*.test.tsx",
        "./__tests__/**/*.test.ts",
        "./__tests__/**/*.test.tsx",
        "./scripts/**/*.test.ts",
        "vitest.setup.ts"
    ]
}
