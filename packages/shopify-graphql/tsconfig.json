{
    "$schema": "https://json.schemastore.org/tsconfig",
    "compilerOptions": {
        "module": "ESNext",
        "moduleResolution": "Bundler",
        "outDir": "./dist",
        "rootDir": "./src",
        "typeRoots": ["./dist/index.d.ts"]
    },
    "exclude": ["node_modules", "coverage", "dist", "**/*.stories.*"],
    "include": ["./src/**/*", "../../@types/declaration.d.ts"]
}
