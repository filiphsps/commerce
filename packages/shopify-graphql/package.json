{
    "$schema": "https://json.schemastore.org/package.json",
    "name": "@nordcom/commerce-shopify-graphql",
    "version": "0.0.0",
    "private": true,
    "sideEffects": false,
    "type": "module",
    "types": "./dist/index.d.ts",
    "module": "./dist/index.ts",
    "exports": {
        ".": [
            "./src/index.ts",
            "./dist/index.js"
        ],
        "./*": [
            "./src/*.ts",
            "./dist/*.js",
            "./src/*/index.ts",
            "./dist/*/index.js"
        ]
    },
    "scripts": {
        "build": "tsc && vite build",
        "clean": "rimraf -g dist coverage .turbo .next *.tsbuildinfo *.log node_modules",
        "lint": "biome lint .",
        "format": "concurrently -i pnpm:format:*",
        "format:lint": "biome lint --write .",
        "format:format": "biome format --write .",
        "format:check": "biome check --write --unsafe .",
        "generate": "pnpm graphql:gen",
        "graphql:schema": "tsx ./scripts/copy-schema.ts",
        "graphql:gen": "pnpm graphql:schema && gql.tada generate-output",
        "graphql:check": "gql.tada check",
        "test": "vitest run",
        "typecheck": "tsc -noEmit"
    },
    "author": {
        "name": "Filiph Sandström",
        "email": "filfat@hotmail.se",
        "url": "https://github.com/filiphsps/"
    },
    "contributors": [
        {
            "name": "Filiph Sandström",
            "email": "filfat@hotmail.se",
            "url": "https://github.com/filiphsps/"
        }
    ],
    "repository": {
        "type": "git",
        "url": "git+https://github.com/filiphsps/commerce.git"
    },
    "keywords": [],
    "bugs": {
        "url": "https://github.com/filiphsps/commerce/issues"
    },
    "homepage": "https://shops.nordcom.io/docs/",
    "files": [
        "dist"
    ],
    "dependencies": {
        "@nordcom/commerce-errors": "workspace:*",
        "gql.tada": "^1.9.2"
    },
    "peerDependencies": {
        "@apollo/client": "3.13.0 || ^4.0.0",
        "graphql": "16.14.0"
    },
    "devDependencies": {
        "@0no-co/graphqlsp": "^1.15.4",
        "@apollo/client": "4.1.9",
        "@codecov/vite-plugin": "2.0.1",
        "@shopify/hydrogen-react": "2026.4.2",
        "concurrently": "9.2.1",
        "glob": "13.0.6",
        "graphql": "16.14.0",
        "rimraf": "6.1.3",
        "tsx": "4.22.3",
        "typescript": "6.0.3",
        "vite": "8.0.14",
        "vitest": "4.1.6"
    }
}
