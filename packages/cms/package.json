{
    "$schema": "https://json.schemastore.org/package.json",
    "name": "@nordcom/commerce-cms",
    "version": "0.1.0",
    "private": true,
    "sideEffects": [
        "**/*.css"
    ],
    "type": "module",
    "types": "./dist/index.d.ts",
    "module": "./dist/index.ts",
    "exports": {
        ".": [
            "./src/index.ts",
            "./dist/index.js"
        ],
        "./blocks": [
            "./src/blocks/index.ts",
            "./dist/blocks/index.js"
        ],
        "./blocks/render": [
            "./src/blocks/render/index.ts",
            "./dist/blocks/render/index.js"
        ],
        "./layout": [
            "./src/layout/index.ts",
            "./dist/layout/index.js"
        ],
        "./extensions": [
            "./src/extensions/index.ts",
            "./dist/extensions/index.js"
        ],
        "./fields": [
            "./src/fields/index.ts",
            "./dist/fields/index.js"
        ],
        "./descriptors": [
            "./src/descriptors/index.ts",
            "./dist/descriptors/index.js"
        ],
        "./responsive": [
            "./src/responsive/index.ts",
            "./dist/responsive/index.js"
        ],
        "./cache": [
            "./src/cache.ts",
            "./dist/cache.js"
        ],
        "./cache-descriptor": [
            "./src/cache-descriptor.ts",
            "./dist/cache-descriptor.js"
        ],
        "./api": [
            "./src/api/index.ts",
            "./dist/api/index.js"
        ],
        "./types": [
            "./src/types/index.ts",
            "./dist/types/index.js"
        ],
        "./editor": [
            "./src/editor/index.ts",
            "./dist/editor/index.js"
        ],
        "./editor/form": [
            "./src/editor/form/index.ts",
            "./dist/editor/form/index.js"
        ],
        "./editor/ui": [
            "./src/editor/ui/index.ts",
            "./dist/editor/ui/index.js"
        ],
        "./editor/manifests": [
            "./src/editor/manifests/index.ts",
            "./dist/editor/manifests/index.js"
        ],
        "./editor/richtext": [
            "./src/editor/richtext/index.ts",
            "./dist/editor/richtext/index.js"
        ],
        "./editor/preview": [
            "./src/editor/preview/index.ts",
            "./dist/editor/preview/index.js"
        ],
        "./media": [
            "./src/media/sizes.ts",
            "./dist/media/sizes.js"
        ],
        "./media/mime-types": [
            "./src/media/mime-types.ts",
            "./dist/media/mime-types.js"
        ],
        "./media/derive": [
            "./src/media/derive.ts",
            "./dist/media/derive.js"
        ],
        "./media/urls": [
            "./src/media/urls.ts",
            "./dist/media/urls.js"
        ]
    },
    "scripts": {
        "build": "vite build",
        "generate": "pnpm cms:gen && tsc",
        "clean": "rimraf -g dist coverage .turbo .next *.tsbuildinfo *.log node_modules",
        "lint": "biome lint .",
        "format": "concurrently -i pnpm:format:*",
        "format:lint": "biome lint --write .",
        "format:format": "biome format --write .",
        "format:check": "biome check --write --unsafe .",
        "typecheck": "tsc -noEmit",
        "cms:gen": "tsx scripts/cms-gen.ts",
        "cms:gen:check": "tsx scripts/cms-gen-check.ts",
        "test": "vitest run --coverage --passWithNoTests --maxWorkers=2 --reporter=default --reporter=junit --outputFile.junit=./junit.xml"
    },
    "files": [
        "dist"
    ],
    "dependencies": {
        "@nordcom/commerce-db": "workspace:*",
        "@nordcom/commerce-errors": "workspace:*",
        "@tagtree/core": "workspace:*",
        "@tagtree/next": "workspace:*",
        "clsx": "2.1.1",
        "server-only": "0.0.1",
        "sharp": "0.35.1",
        "tailwind-merge": "3.6.0"
    },
    "peerDependencies": {
        "next": "16.2.6",
        "next-auth": "5.0.0-beta.31",
        "react": "19.2.6",
        "react-dom": "19.2.6"
    },
    "devDependencies": {
        "@codecov/vite-plugin": "2.0.1",
        "@testing-library/react": "16.3.2",
        "@types/node": "25.9.3",
        "@types/react": "19.2.17",
        "concurrently": "10.0.3",
        "happy-dom": "20.10.3",
        "next": "16.2.9",
        "next-auth": "5.0.0-beta.31",
        "prosemirror-model": "^1.25.8",
        "react": "19.2.7",
        "react-dom": "19.2.7",
        "rimraf": "6.1.3",
        "tsx": "4.22.4",
        "typescript": "6.0.3",
        "vite": "8.0.16",
        "vitest": "4.1.8"
    }
}
