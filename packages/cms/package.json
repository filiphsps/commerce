{
    "$schema": "https://json.schemastore.org/package.json",
    "name": "@nordcom/commerce-cms",
    "version": "0.1.0",
    "private": true,
    "sideEffects": false,
    "type": "module",
    "types": "./dist/index.d.ts",
    "module": "./dist/index.ts",
    "exports": {
        ".": [
            "./src/index.ts",
            "./dist/index.js"
        ],
        "./config": [
            "./src/config/index.ts",
            "./dist/config/index.js"
        ],
        "./collections": [
            "./src/collections/index.ts",
            "./dist/collections/index.js"
        ],
        "./blocks": [
            "./src/blocks/index.ts",
            "./dist/blocks/index.js"
        ],
        "./blocks/render": [
            "./src/blocks/render/index.ts",
            "./dist/blocks/render/index.js"
        ],
        "./fields": [
            "./src/fields/index.ts",
            "./dist/fields/index.js"
        ],
        "./access": [
            "./src/access/index.ts",
            "./dist/access/index.js"
        ],
        "./api": [
            "./src/api/index.ts",
            "./dist/api/index.js"
        ],
        "./auth": [
            "./src/auth/index.ts",
            "./dist/auth/index.js"
        ],
        "./plugins": [
            "./src/plugins/index.ts",
            "./dist/plugins/index.js"
        ],
        "./types": [
            "./src/types/index.ts",
            "./dist/types/index.js"
        ],
        "./test-utils": [
            "./src/test-utils/index.ts",
            "./dist/test-utils/index.js"
        ],
        "./shop-sync": [
            "./src/shop-sync/index.ts",
            "./dist/shop-sync/index.js"
        ]
    },
    "scripts": {
        "build": "tsc && vite build",
        "clean": "rimraf -g dist coverage .turbo .next *.tsbuildinfo *.log node_modules",
        "lint": "biome lint .",
        "format": "concurrently -i pnpm:format:*",
        "format:lint": "biome lint --write .",
        "format:format": "biome format --write .",
        "format:check": "biome check --write --unsafe .",
        "typecheck": "tsc -noEmit",
        "generate:types": "PAYLOAD_CONFIG_PATH=src/types/generate-types-config.ts payload generate:types --output ./src/types/payload-types.ts"
    },
    "files": [
        "dist"
    ],
    "dependencies": {
        "@nordcom/commerce-db": "workspace:*",
        "@nordcom/commerce-errors": "workspace:*",
        "@panva/hkdf": "1.2.1",
        "jose": "5.9.0",
        "server-only": "0.0.1"
    },
    "peerDependencies": {
        "@payloadcms/db-mongodb": "^3.84.0",
        "@payloadcms/next": "^3.84.0",
        "@payloadcms/plugin-multi-tenant": "^3.84.0",
        "@payloadcms/richtext-lexical": "^3.84.0",
        "@payloadcms/storage-s3": "^3.84.0",
        "next": "^16.2.6",
        "next-auth": "^5.0.0-beta.31",
        "payload": "^3.84.0",
        "react": "^19.2.0",
        "react-dom": "^19.2.0"
    },
    "devDependencies": {
        "@codecov/vite-plugin": "2.0.1",
        "@payloadcms/db-mongodb": "3.84.0",
        "@payloadcms/next": "3.84.0",
        "@payloadcms/plugin-multi-tenant": "3.84.0",
        "@payloadcms/richtext-lexical": "3.84.0",
        "@payloadcms/storage-s3": "3.84.0",
        "@testing-library/react": "16.1.0",
        "@types/node": "24.12.4",
        "@types/react": "19.2.14",
        "concurrently": "9.2.1",
        "happy-dom": "16.5.3",
        "next": "16.2.6",
        "next-auth": "5.0.0-beta.31",
        "payload": "3.84.0",
        "react": "19.2.6",
        "react-dom": "19.2.6",
        "rimraf": "6.1.3",
        "typescript": "6.0.3",
        "vite": "8.0.12",
        "vite-plugin-dts": "5.0.0",
        "vite-tsconfig-paths": "6.1.1",
        "vitest": "4.1.6"
    }
}
