{
    "$schema": "https://json.schemastore.org/package.json",
    "name": "@nordcom/commerce-test-convex",
    "version": "0.0.0",
    "private": true,
    "type": "module",
    "types": "./dist/index.d.ts",
    "module": "./dist/index.ts",
    "exports": {
        ".": [
            "./dist/index.js",
            "./src/index.ts"
        ],
        "./start": [
            "./dist/start.js",
            "./src/start.ts"
        ],
        "./daemon": [
            "./dist/daemon.js",
            "./src/daemon.ts"
        ],
        "./cli": [
            "./dist/cli.js",
            "./src/cli.ts"
        ],
        "./unit": [
            "./dist/unit.js",
            "./src/unit.ts"
        ],
        "./seed/*": [
            "./dist/seed/*.js",
            "./src/seed/*.ts"
        ]
    },
    "bin": {
        "test-convex": "./dist/cli.js"
    },
    "files": [
        "dist"
    ],
    "scripts": {
        "build": "tsc",
        "clean": "rimraf -g dist coverage .turbo *.tsbuildinfo *.log node_modules",
        "lint": "biome lint .",
        "format:check": "biome check --write --unsafe .",
        "test": "vitest run",
        "typecheck": "tsc -noEmit"
    },
    "dependencies": {
        "@nordcom/commerce-cms": "workspace:*",
        "convex": "1.41.0",
        "convex-test": "0.0.53"
    },
    "devDependencies": {
        "rimraf": "6.1.3",
        "typescript": "6.0.3",
        "vitest": "4.1.7"
    }
}
