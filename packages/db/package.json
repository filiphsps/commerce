{
    "$schema": "https://json.schemastore.org/package.json",
    "name": "@nordcom/commerce-db",
    "version": "0.1.0",
    "private": true,
    "sideEffects": false,
    "type": "module",
    "types": "./dist/index.d.ts",
    "module": "./dist/index.ts",
    "exports": {
        ".": [
            "./src/index.ts",
            "./dist/index.js"
        ],
        "./*": [
            "./src/*.ts",
            "./dist/*.js",
            "./src/*/index.ts",
            "./dist/*/index.js"
        ]
    },
    "scripts": {
        "build": "tsc && vite build",
        "clean": "rimraf -g dist coverage .turbo .next *.tsbuildinfo *.log node_modules",
        "lint": "biome lint .",
        "format": "concurrently -i pnpm:format:*",
        "format:lint": "biome lint --write .",
        "format:format": "biome format --write .",
        "format:check": "biome check --write --unsafe .",
        "typecheck": "tsc -noEmit"
    },
    "author": {
        "name": "Nordcom AB",
        "email": "hi@nordcom.io",
        "url": "https://nordcom.io/"
    },
    "contributors": [
        {
            "name": "Filiph Sandström",
            "email": "filfat@hotmail.se",
            "url": "https://github.com/filiphsps/"
        }
    ],
    "repository": {
        "type": "git",
        "url": "git+https://github.com/filiphsps/commerce.git"
    },
    "keywords": [],
    "bugs": {
        "url": "https://github.com/filiphsps/commerce/issues"
    },
    "homepage": "https://github.com/filiphsps/commerce/",
    "files": [
        "dist"
    ],
    "dependencies": {
        "@nordcom/commerce-errors": "workspace:*",
        "mongoose": "9.6.2"
    },
    "devDependencies": {
        "@codecov/vite-plugin": "2.0.1",
        "@types/node": "24.12.4",
        "@typescript/native-preview": "7.0.0-dev.20260515.1",
        "concurrently": "9.2.1",
        "glob": "13.0.6",
        "rimraf": "6.1.3",
        "server-only": "0.0.1",
        "typescript": "6.0.3",
        "vite": "8.0.12",
        "vitest": "4.1.6"
    }
}
