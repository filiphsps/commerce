{
    "$schema": "https://json.schemastore.org/tsconfig",
    "extends": "../../../tsconfig.lib.json",
    "compilerOptions": {
        "lib": ["ESNext"],
        "types": ["node"],
        "baseUrl": ".",
        "paths": {
            "@/*": ["./src/*"]
        }
    },
    "include": ["./src/**/*.ts"],
    "exclude": ["node_modules", "dist", "coverage", "**/*.test.ts", "tests"]
}
