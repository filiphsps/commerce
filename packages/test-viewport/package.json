{
    "$schema": "https://json.schemastore.org/package.json",
    "name": "@nordcom/commerce-test-viewport",
    "version": "0.0.0",
    "private": true,
    "type": "module",
    "types": "./dist/index.d.ts",
    "module": "./dist/index.ts",
    "exports": {
        ".": [
            "./dist/index.js",
            "./src/index.ts"
        ],
        "./presets": [
            "./dist/presets.js",
            "./src/presets.ts"
        ],
        "./matchmedia": [
            "./dist/matchmedia.js",
            "./src/matchmedia.ts"
        ],
        "./playwright": [
            "./dist/playwright.js",
            "./src/playwright.ts"
        ]
    },
    "files": [
        "dist"
    ],
    "scripts": {
        "build": "tsc",
        "clean": "rimraf -g dist coverage .turbo *.tsbuildinfo *.log node_modules",
        "lint": "biome lint .",
        "format:check": "biome check --write --unsafe .",
        "test": "vitest run --coverage --passWithNoTests --maxWorkers=2 --reporter=default --reporter=junit --outputFile.junit=./junit.xml",
        "typecheck": "tsc -noEmit"
    },
    "devDependencies": {
        "@playwright/test": "1.60.0",
        "rimraf": "6.1.3",
        "typescript": "6.0.3",
        "vitest": "4.1.8"
    },
    "peerDependencies": {
        "@playwright/test": ">=1.40.0"
    },
    "peerDependenciesMeta": {
        "@playwright/test": {
            "optional": true
        }
    }
}
