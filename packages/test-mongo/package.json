{
    "$schema": "https://json.schemastore.org/package.json",
    "name": "@nordcom/commerce-test-mongo",
    "version": "0.0.0",
    "private": true,
    "type": "module",
    "types": "./dist/index.d.ts",
    "module": "./dist/index.ts",
    "exports": {
        ".": [
            "./dist/index.js",
            "./src/index.ts"
        ],
        "./daemon": [
            "./dist/daemon.js",
            "./src/daemon.ts"
        ],
        "./start": [
            "./dist/start.js",
            "./src/start.ts"
        ],
        "./loader": [
            "./src/server-only-loader.mjs"
        ],
        "./register": [
            "./src/register-loaders.mjs"
        ],
        "./seed-loader": [
            "./src/seed-loader.mjs"
        ],
        "./register-seed-loaders": [
            "./src/register-seed-loaders.mjs"
        ]
    },
    "bin": {
        "test-mongo": "./dist/cli.js"
    },
    "files": [
        "dist"
    ],
    "scripts": {
        "build": "tsc && vite build",
        "clean": "rimraf -g dist coverage .turbo *.tsbuildinfo *.log node_modules",
        "lint": "biome lint .",
        "format:check": "biome check --write --unsafe .",
        "test": "vitest run",
        "typecheck": "tsc -noEmit"
    },
    "dependencies": {
        "@nordcom/commerce-cms": "workspace:*",
        "@nordcom/commerce-db": "workspace:*",
        "@payloadcms/db-mongodb": "3.85.0",
        "mongodb-memory-server": "11.1.0",
        "mongoose": "9.6.3",
        "payload": "3.85.0"
    },
    "devDependencies": {
        "@codecov/vite-plugin": "2.0.1",
        "rimraf": "6.1.3",
        "typescript": "6.0.3",
        "vite": "8.0.14",
        "vitest": "4.1.7"
    }
}
