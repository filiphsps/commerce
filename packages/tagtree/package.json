{
    "$schema": "https://json.schemastore.org/package.json",
    "name": "tagtree",
    "version": "0.0.0",
    "private": true,
    "sideEffects": false,
    "type": "module",
    "types": "./dist/index.d.ts",
    "module": "./dist/index.js",
    "exports": {
        ".": [
            "./src/index.ts",
            "./dist/index.js"
        ],
        "./contract-tests": [
            "./src/contract-tests.ts",
            "./dist/contract-tests.js"
        ]
    },
    "scripts": {
        "build": "tsc && vite build",
        "clean": "rimraf -g dist coverage .turbo .next *.tsbuildinfo *.log node_modules",
        "lint": "biome lint .",
        "format:check": "biome check --write --unsafe .",
        "test": "vitest run",
        "typecheck": "tsc -noEmit"
    },
    "files": ["dist"],
    "dependencies": {},
    "devDependencies": {
        "@codecov/vite-plugin": "2.0.1",
        "concurrently": "9.2.1",
        "rimraf": "6.1.3",
        "typescript": "6.0.3",
        "vite": "8.0.12",
        "vite-plugin-dts": "5.0.0",
        "vite-tsconfig-paths": "6.1.1",
        "vitest": "4.1.6"
    }
}
