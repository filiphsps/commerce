{
  "$schema": "https://anthropic.com/claude-code/marketplace.schema.json",
  "name": "commerce-plugins",
  "description": "Repo-local Claude Code plugins for the commerce monorepo.",
  "owner": {
    "name": "Nordcom Commerce",
    "email": "dev@nordcom.io"
  },
  "plugins": [
    {
      "name": "tailwind-lsp-adapter",
      "description": "Tailwind CSS LSP for Claude Code - completions, hover info, and diagnostics for Tailwind classes.",
      "version": "1.0.0",
      "author": {
        "name": "Nordcom Commerce",
        "email": "dev@nordcom.io"
      },
      "source": "./tailwind-lsp-adapter",
      "category": "development",
      "strict": false,
      "lspServers": {
        "tailwindcss": {
          "command": "pnpm",
          "args": [
            "dlx",
            "--package",
            "tailwind-lsp-adapter@1.1.5",
            "--package",
            "@tailwindcss/language-server@0.14.29",
            "tailwind-lsp-adapter"
          ],
          "extensionToLanguage": {
            ".css": "css",
            ".scss": "scss",
            ".less": "less",
            ".html": "html",
            ".js": "javascript",
            ".jsx": "javascriptreact",
            ".ts": "typescript",
            ".tsx": "typescriptreact",
            ".vue": "vue",
            ".svelte": "svelte"
          }
        }
      }
    },
    {
      "name": "typescript-lsp",
      "description": "TypeScript/JavaScript LSP for Claude Code - go-to-definition, find references, hover, and diagnostics.",
      "version": "1.0.0",
      "author": {
        "name": "Nordcom Commerce",
        "email": "dev@nordcom.io"
      },
      "source": "./typescript-lsp",
      "category": "development",
      "strict": false,
      "lspServers": {
        "typescript": {
          "command": "pnpm",
          "args": [
            "dlx",
            "typescript-language-server@4.4.1",
            "--stdio"
          ],
          "extensionToLanguage": {
            ".ts": "typescript",
            ".tsx": "typescriptreact",
            ".js": "javascript",
            ".jsx": "javascriptreact",
            ".mts": "typescript",
            ".cts": "typescript",
            ".mjs": "javascript",
            ".cjs": "javascript"
          }
        }
      }
    }
  ]
}
