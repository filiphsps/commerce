{
  "tailwindcss": {
    "command": "pnpm",
    "args": [
      "dlx",
      "--package",
      "tailwind-lsp-adapter@1.1.5",
      "--package",
      "@tailwindcss/language-server@0.14.29",
      "tailwind-lsp-adapter"
    ],
    "extensionToLanguage": {
      ".css": "css",
      ".scss": "scss",
      ".less": "less",
      ".html": "html",
      ".js": "javascript",
      ".jsx": "javascriptreact",
      ".ts": "typescript",
      ".tsx": "typescriptreact",
      ".vue": "vue",
      ".svelte": "svelte"
    }
  }
}
