{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "includeCoAuthoredBy": false,
  "enableAllProjectMcpServers": true,
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/filter-test-output.sh"
          },
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/filter-lint-output.sh"
          },
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/filter-typecheck-output.sh"
          },
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/filter-build-output.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/block-npm.sh"
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "pnpm biome check --write $CLAUDE_FILE_PATHS 2>&1 || true"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/fallow-check.sh"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "compact",
        "hooks": [
          {
            "type": "command",
            "command": "printf '## Project CLAUDE.md re-injected after compaction (these instructions override default behavior):\\n\\n'; cat \"$CLAUDE_PROJECT_DIR/CLAUDE.md\""
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "typescript-lsp@claude-plugins-official": false,
    "superpowers@superpowers-marketplace": true,
    "mongodb@claude-plugins-official": false,
    "playwright@claude-plugins-official": true,
    "frontend-design@claude-plugins-official": true,
    "typescript-lsp@commerce-plugins": true,
    "double-shot-latte@superpowers-marketplace": true,
    "tailwind-lsp-adapter@commerce-plugins": true
  },
  "extraKnownMarketplaces": {
    "superpowers-marketplace": {
      "source": {
        "source": "github",
        "repo": "obra/superpowers-marketplace"
      }
    },
    "commerce-plugins": {
      "source": {
        "source": "directory",
        "path": ".claude/plugins/commerce-plugins"
      }
    }
  },
  "showThinkingSummaries": true,
  "useAutoModeDuringPlan": true
}
