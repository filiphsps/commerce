{
    "$schema": "https://json.schemastore.org/package.json",
    "name": "@nordcom/commerce",
    "version": "2.1.0",
    "private": true,
    "type": "module",
    "cacheDirectories": [
        ".next/cache",
        "apps/**/.next/cache"
    ],
    "workspaces": [
        "apps/*",
        "packages/*"
    ],
    "scripts": {
        "analyze": "dotenv -c -- turbo run analyze --env-mode=loose",
        "predev": "portless proxy status >/dev/null 2>&1 || portless proxy start --https --wildcard",
        "predev:admin": "pnpm predev",
        "predev:landing": "pnpm predev",
        "predev:storefront": "pnpm predev",
        "predev:docs": "pnpm predev",
        "dev": "NODE_ENV=development dotenv -c -- portless -- --env-mode=loose",
        "dev:all": "NODE_ENV=development dotenv -c -- turbo run dev --env-mode=loose",
        "dev:admin": "NODE_ENV=development dotenv -c -- portless run --name admin -- turbo run dev --filter=./apps/admin --env-mode=loose",
        "dev:landing": "NODE_ENV=development dotenv -c -- portless run --name landing -- turbo run dev --filter=./apps/landing --env-mode=loose",
        "dev:storefront": "NODE_ENV=development dotenv -c -- portless run --name storefront -- turbo run dev --filter=./apps/storefront --env-mode=loose",
        "dev:docs": "NODE_ENV=development dotenv -c -- portless run --name docs -- turbo run dev --filter=./apps/docs --env-mode=loose",
        "build": "dotenv -c -- turbo run build --env-mode=loose",
        "build:admin": "dotenv -c -- turbo run build --filter=./apps/admin --env-mode=loose",
        "build:landing": "dotenv -c -- turbo run build --filter=./apps/landing --env-mode=loose",
        "build:storefront": "dotenv -c -- turbo run build --filter=./apps/storefront --env-mode=loose",
        "build:docs": "dotenv -c -- turbo run build --filter=./apps/docs --env-mode=loose",
        "build:apps": "dotenv -c -- turbo run build --filter=./apps/** --env-mode=loose",
        "build:packages": "turbo run build --filter=./packages/** --env-mode=loose",
        "generate": "dotenv -c -- turbo run generate --env-mode=loose",
        "clean": "turbo run clean",
        "lint": "biome lint .",
        "format": "concurrently -i pnpm:format:*",
        "format:lint": "biome lint --write .",
        "format:format": "biome format --write .",
        "format:check": "biome check --write --unsafe .",
        "typecheck": "turbo run typecheck",
        "test": "dotenv -c -- vitest run --coverage",
        "test:watch": "dotenv -c -- vitest watch",
        "test:e2e": "dotenv -c -- turbo run test:e2e",
        "cms:gen": "pnpm --filter @nordcom/commerce-cms cms:gen",
        "cms:gen:check": "pnpm --filter @nordcom/commerce-cms cms:gen:check",
        "docs:gen:check": "pnpm --filter @nordcom/commerce-docs docs:gen:check",
        "changeset": "changeset",
        "changeset:version": "changeset version",
        "changeset:publish": "pnpm build:packages && changeset publish"
    },
    "author": {
        "name": "Filiph Sandström",
        "email": "filfat@hotmail.se",
        "url": "https://github.com/filiphsps/"
    },
    "contributors": [
        {
            "name": "Filiph Sandström",
            "email": "filfat@hotmail.se",
            "url": "https://github.com/filiphsps/"
        }
    ],
    "repository": {
        "type": "git",
        "url": "git+https://github.com/filiphsps/commerce.git"
    },
    "keywords": [
        "nextjs",
        "react"
    ],
    "bugs": {
        "url": "https://github.com/filiphsps/commerce/issues"
    },
    "homepage": "https://github.com/filiphsps/commerce/",
    "dependencies": {
        "@nordcom/nordstar": "0.0.75"
    },
    "devDependencies": {
        "@biomejs/biome": "2.4.15",
        "@changesets/changelog-github": "0.7.0",
        "@changesets/cli": "2.31.0",
        "@types/node": "24.12.4",
        "@types/react": "19.2.14",
        "@types/react-dom": "19.2.3",
        "@vitejs/plugin-react": "6.0.1",
        "@vitest/coverage-v8": "4.1.6",
        "babel-plugin-module-resolver": "5.0.3",
        "concurrently": "9.2.1",
        "dotenv-cli": "11.0.0",
        "esbuild": "0.28.0",
        "glob": "13.0.6",
        "import-in-the-middle": "3.0.1",
        "jsdom": "29.1.1",
        "mongoose": "9.6.2",
        "portless": "0.13.0",
        "react": "19.2.6",
        "turbo": "2.9.14",
        "turbo-ignore": "2.9.14",
        "typescript": "6.0.3",
        "unplugin-dts": "1.0.0",
        "vite": "8.0.12",
        "vitest": "4.1.6"
    },
    "packageManager": "pnpm@11.1.2"
}
