# dependencies
node_modules/
.pnp/
.pnp.js
.pnpm-store/

# testing
coverage/
apps/**/coverage/
junit.xml

# next.js
.next
# Isolated dist dir the local e2e harness builds into (see playwright.config.ts).
.next-e2e
next.lock/
out/
dist/
/apps/certificates/

# production
build/
.env.local
apps/**/public/**/sitemap*.xml*
apps/**/public/**/robots.txt*
*ts.timestamp-*
apps/docs/content/*/meta.json

# misc
.DS_Store
.swc

# Convex anonymous local-backend state created by `convex dev`/`convex codegen`
# when no deployment is configured. The generated `_generated/` types ARE
# committed, but local backend state and per-package .env.local must not be.
.convex/
.convex-local/
packages/convex/.env.local
.bak
docs/superpowers/
/.worktrees/
.superpowers/
.portless/
next-env.d.ts
avt_outputs/

# CMS editor server-action wrappers — codegen output of `pnpm cms:gen`
# (reads packages/cms editor manifests). Regenerated at build time; never edit
# or commit by hand.
apps/admin/src/lib/cms-actions/_generated/

# apps/docs generated artifacts
apps/docs/.typedoc-out/
apps/docs/app/docs/(generated)/
apps/docs/public/_pagefind/
apps/docs/.docusaurus/
apps/docs/.source/

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.playwright-mcp/

# deployment
.vercel
.env*
!.env.example
.vercel

# typescript
*.tsbuildinfo
.turbo

# Playwright
playwright-report/
test-results/
blob-report/
playwright/.cache/

# docs site
apps/docs/.docusaurus/
apps/docs/api/

# TypeDoc output is emitted to apps/docs/api/ and symlinked into each
# workspace's docs/api directory by apps/docs/scripts/link-api-docs.mjs.
apps/*/docs/api
packages/*/docs/api
packages/**/docs/api

# Local worktrees (created by superpowers/using-git-worktrees).
.worktrees/
worktrees/
*.png

# Claude Code runtime lock — machine-local, must not be tracked.
.claude/scheduled_tasks.lock
