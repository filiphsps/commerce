{
    "lspmesh": {
        "command": "pnpm",
        "args": ["dlx", "lspmesh@0.0.2", "lsp"],
        "extensionToLanguage": {
            ".ts": "typescript",
            ".tsx": "typescriptreact",
            ".mts": "typescript",
            ".cts": "typescript",
            ".js": "javascript",
            ".jsx": "javascriptreact",
            ".mjs": "javascript",
            ".cjs": "javascript",
            ".css": "css",
            ".scss": "scss",
            ".json": "json",
            ".jsonc": "jsonc"
        }
    }
}
