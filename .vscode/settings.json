{
    "[git-commit]": {
        "editor.rulers": [72, 120],
        "editor.wordWrap": "off",
        "workbench.editor.restoreViewState": false
    },
    "[json]": {
        "editor.defaultFormatter": "biomejs.biome"
    },
    "[jsonc]": {
        "editor.defaultFormatter": "biomejs.biome"
    },
    "[markdown]": {
        "editor.formatOnType": true
    },
    "[plaintext]": {
        "editor.formatOnSave": false
    },
    "[tailwindcss]": {
        "editor.quickSuggestions": {
            "strings": "on"
        }
    },
    "[typescript]": {
        "editor.defaultFormatter": "biomejs.biome"
    },
    "[typescriptreact]": {
        "editor.defaultFormatter": "biomejs.biome"
    },
    "biome.requireConfiguration": true,
    "claudeCode.allowDangerouslySkipPermissions": true,
    "claudeCode.hideOnboarding": true,
    "claudeCode.initialPermissionMode": "bypassPermissions",
    "claudeCode.usePythonEnvironment": false,
    "cSpell.words": [
        "Albin",
        "autofocus",
        "Bergsgatan",
        "changefreq",
        "cmdk",
        "Codegen",
        "colord",
        "compat",
        "Componentizable",
        "Dahlqvist",
        "datasource",
        "Deca",
        "dotenvx",
        "ecomm",
        "ecommerce",
        "endonym",
        "Etags",
        "extensionless",
        "Filenaming",
        "Filiph",
        "filiphsandstrom",
        "filiphsps",
        "googlebot",
        "Götaland",
        "hrefs",
        "HSTS",
        "ipgeolocation",
        "jsonld",
        "jsxdev",
        "Judgeme",
        "klaviyo",
        "labelledby",
        "lastmod",
        "learnq",
        "Lexend",
        "Lightningcss",
        "lucide",
        "markdoc",
        "Mellerud",
        "metafield",
        "metafields",
        "Metaobject",
        "myshopify",
        "Navigations",
        "neshca",
        "nextauth",
        "nextjs",
        "nextra",
        "Nordcom",
        "Nordstar",
        "nosnippet",
        "npmjs",
        "nprogress",
        "nums",
        "nvmrc",
        "overscroll",
        "pagetype",
        "payloadcms",
        "PECR",
        "postbuild",
        "predev",
        "Preloadable",
        "registrator",
        "renderable",
        "Sädesbingen",
        "Sahlin",
        "Sandström",
        "signin",
        "Siitam",
        "slicemachine",
        "Sobolewski",
        "sonner",
        "stringifier",
        "stylesheet",
        "Subframes",
        "svgs",
        "svgson",
        "sweetsideofsweden",
        "tagtree",
        "tailwindcss",
        "testid",
        "thirdparties",
        "thumbhash",
        "timeframes",
        "toploader",
        "treeshake",
        "Trollhättan",
        "tsbuildinfo",
        "turborepo",
        "Turborepo",
        "typecheck",
        "unoptimized",
        "uuidv",
        "Västra",
        "Vercel",
        "VIEWPORTS",
        "virtuals",
        "wakatime",
        "webp",
        "Woohoo",
        "wordmark",
        "xlink"
    ],
    "editor.codeActionsOnSave": {
        "source.fixAll.biome": "explicit",
        "source.organizeImports.biome": "explicit"
    },
    "editor.defaultFormatter": "biomejs.biome",
    "editor.formatOnSave": true,
    "editor.quickSuggestions": {
        "strings": true
    },
    "editor.renderWhitespace": "all",
    "editor.rulers": [120],
    "editor.wordWrap": "bounded",
    "editor.wordWrapColumn": 120,
    "files.associations": {
        ".renovaterc": "json",
        "*.css": "tailwindcss",
        "**/*.hbs": "plaintext",
        "LICENSE": "plaintext"
    },
    "files.autoSave": "off",
    "files.eol": "\n",
    "files.exclude": {
        "**/.DS_Store": true,
        "**/.git": true,
        "**/.hg": true,
        "**/.next": true,
        "**/.svn": true,
        "**/*.tsbuildinfo": true,
        "**/CVS": true,
        "**/junit.xml": true,
        "**/Thumbs.db": true
    },
    "files.trimFinalNewlines": false,
    "files.trimTrailingWhitespace": true,
    "git.autofetch": "all",
    "git.autofetchPeriod": 30,
    "git.countBadge": "tracked",
    "git.defaultBranchName": "master",
    "git.enableCommitSigning": true,
    "git.fetchOnPull": true,
    "git.inputValidation": true,
    "git.inputValidationLength": 72,
    "git.inputValidationSubjectLength": 72,
    "git.mergeEditor": false,
    "git.showPushSuccessNotification": true,
    "git.similarityThreshold": 72,
    "js/ts.inlayHints.enumMemberValues.enabled": true,
    "js/ts.inlayHints.functionLikeReturnTypes.enabled": true,
    "js/ts.inlayHints.parameterNames.suppressWhenArgumentMatchesName": true,
    "js/ts.inlayHints.parameterTypes.enabled": true,
    "js/ts.inlayHints.propertyDeclarationTypes.enabled": true,
    "js/ts.inlayHints.variableTypes.enabled": true,
    "js/ts.locale": "en",
    "js/ts.tsdk.path": "./node_modules/typescript/lib",
    "js/ts.updateImportsOnFileMove.enabled": "prompt",
    "npm.packageManager": "pnpm",
    "npm.scriptRunner": "pnpm",
    "tailwindCSS.classAttributes": ["class", "className", ".*ClassName", ".*Styles"],
    "tailwindCSS.colorDecorators": true,
    "tailwindCSS.experimental.classRegex": [
        "[a-zA-Z]*ClassName='([^']+)'",
        "[a-zA-Z]*ClassName=\"([^\"]+)\"",
        "[a-zA-Z]*ClassName={`([^`]+)`}",
        "[a-zA-Z]*ClassName={`([^`]+)`}",
        ["Styles\\s*=\\s*([^;]*);", "'([^']*)'"],
        ["Styles\\s*=\\s*([^;]*);", "\"([^\"]*)\""],
        ["Styles\\s*=\\s*([^;]*);", "\\`([^\\`]*)\\`"],
        ["cva\\(([^)]*)\\)", "[\"'`]([^\"'`]*).*?[\"'`]"],
        ["cx\\(([^)]*)\\)", "(?:'|\"|`)([^']*)(?:'|\"|`)"]
    ],
    "tailwindCSS.experimental.configFile": {
        "apps/admin/src/app/globals.css": "apps/admin/**",
        "apps/docs/app/globals.css": "apps/docs/**",
        "apps/landing/src/app/globals.css": "apps/landing/**",
        "apps/storefront/src/app/globals.css": "apps/storefront/**"
    },
    "tailwindCSS.lint.cssConflict": "error",
    "tailwindCSS.lint.invalidVariant": "warning",
    "typescript.native-preview.goMemLimit": "2048MiB",
    "vitest.rootConfig": "./vitest.config.ts",
    "vitest.showImportsDuration": false,
    "vitest.workspaceConfig": "./vitest.workspace.ts"
}
