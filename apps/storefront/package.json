{
    "$schema": "https://json.schemastore.org/package.json",
    "name": "@nordcom/commerce-storefront",
    "version": "2.0.0",
    "private": true,
    "sideEffects": false,
    "type": "module",
    "cacheDirectories": [
        ".next/cache"
    ],
    "scripts": {
        "start": "next start -p $PORT",
        "dev": "next dev -p 1337 --turbo",
        "build": "node ./scripts/build.mjs",
        "clean": "rimraf -g dist coverage .turbo .next .tsbuildinfo *.log",
        "lint": "biome lint .",
        "format": "concurrently -i pnpm:format:*",
        "format:lint": "biome lint --write .",
        "format:format": "biome format --write .",
        "format:check": "biome check --write --unsafe .",
        "typecheck": "tsc -noEmit",
        "slicemachine": "start-slicemachine",
        "test:e2e": "playwright test"
    },
    "author": {
        "name": "Nordcom AB",
        "email": "hi@nordcom.io",
        "url": "https://nordcom.io/"
    },
    "contributors": [
        {
            "name": "Filiph Siitam Sandström",
            "email": "filiph@nordcom.io",
            "url": "https://github.com/filiphsps/"
        }
    ],
    "repository": {
        "type": "git",
        "url": "git+https://github.com/filiphsps/commerce.git"
    },
    "keywords": [
        "nextjs",
        "react"
    ],
    "bugs": {
        "url": "https://github.com/filiphsps/commerce/issues"
    },
    "homepage": "https://shops.nordcom.io/",
    "dependencies": {
        "@apollo/client": "4.1.9",
        "@auth/core": "0.41.2",
        "@next/third-parties": "16.2.6",
        "@nordcom/commerce-db": "workspace:*",
        "@nordcom/commerce-errors": "workspace:*",
        "@nordcom/commerce-shopify-graphql": "workspace:*",
        "@nordcom/commerce-shopify-html": "workspace:*",
        "@nordcom/nordstar": "0.0.74",
        "@opentelemetry/api-logs": "0.217.0",
        "@opentelemetry/instrumentation": "0.217.0",
        "@opentelemetry/sdk-logs": "0.217.0",
        "@prismicio/client": "7.21.8",
        "@prismicio/next": "1.7.1",
        "@prismicio/react": "2.9.1",
        "@radix-ui/react-dialog": "1.1.15",
        "@radix-ui/react-visually-hidden": "1.2.4",
        "@sentry/nextjs": "10.53.0",
        "@sentry/profiling-node": "10.53.0",
        "@shopify/hydrogen-react": "2026.4.2",
        "@vercel/analytics": "2.0.1",
