        "@vercel/toolbar": "0.2.5",
        "clsx": "2.1.1",
        "colord": "2.9.3",
        "convert-units": "2.3.4",
        "cookies-next": "6.1.1",
        "country-code-lookup": "0.1.5",
        "crypto-js": "4.2.0",
        "export-to-csv": "1.4.0",
        "lodash.debounce": "4.0.8",
        "lucide-react": "1.14.0",
        "next": "16.2.6",
        "next-auth": "5.0.0-beta.31",
        "next-sitemap": "4.2.3",
        "nextjs-toploader": "3.9.17",
