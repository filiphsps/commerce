{
    "$schema": "https://json.schemastore.org/tsconfig",
    "extends": "../../tsconfig.app.json",
    "compilerOptions": {
        "paths": {
            "@/app/*": ["./src/app/*"],
            "@/middleware/*": ["./src/middleware/*"],
            "@/components/*": ["./src/components/*"],
            "@/hooks/*": ["./src/hooks/*"],
            "@/api/*": ["./src/api/*"],
            "@/auth": ["./src/auth/auth.ts"],
            "@/auth/*": ["./src/auth/*"],
            "@/cache": ["./src/cache.ts"],
            "@/models/*": ["./src/models/*"],
            "@/utils/*": ["./src/utils/*"],
            "@/utils/locale": ["./src/utils/locale/index.ts"],
            "@/styles/*": ["./src/scss/*"],
            "@/pages/*": ["./src/app/[domain]/[locale]/*"],
            "@/i18n/*": ["./src/locales/*"],
            "@/i18n/dictionary": ["./src/utils/dictionary.ts"],
            "@/static/*": ["./public/*"]
        }
    },
    "include": [
        "next-env.d.ts",
        "./src/**/*.ts",
        "./src/**/.well-known/**/*.ts",
        "./src/**/*.tsx",
        ".next/types/**/*.ts",
        ".next/dev/types/**/*.ts"
    ]
}
