# Multi-tenant storefront — required env vars

MONGODB_URI=mongodb://localhost:27017/commerce
SERVICE_DOMAIN=landing.localhost

# Convex backend. CONVEX_URL for server-side clients, NEXT_PUBLIC_CONVEX_URL for
# the browser; CONVEX_DEPLOY_KEY authenticates `convex deploy`/codegen in CI.
CONVEX_URL=
CONVEX_DEPLOY_KEY=
NEXT_PUBLIC_CONVEX_URL=
# HMAC secret for /api/revalidate/convex — Convex signs revalidation events with
# this and the route verifies it BEFORE any tenant/cache work. Distinct from
# SHOPIFY_WEBHOOK_SECRET (different name + purpose). Rotation (dual-accept): the
# Convex deployment signs with ONLY the current value (it never reads _PREVIOUS);
# the route verifies against {current, previous}. Set _PREVIOUS to the prior
# value during the rotation window so in-flight deliveries signed with the old
# secret still verify (200) — they 401 once _PREVIOUS is unset.
CONVEX_REVALIDATE_SECRET=
CONVEX_REVALIDATE_SECRET_PREVIOUS=
# Convex auth — the storefront mints a NextAuth-derived RS256 JWT the Convex
# deployment validates. CONVEX_AUTH_ISSUER = `iss` claim, CONVEX_AUTH_APPLICATION_ID
# = `aud` claim; CONVEX_AUTH_JWKS_URL is the deployment's key source (defaults to
# ${CONVEX_AUTH_ISSUER}/.well-known/jwks.json).
CONVEX_AUTH_ISSUER=
CONVEX_AUTH_APPLICATION_ID=
CONVEX_AUTH_JWKS_URL=
# RS256 signing key (PKCS8 PEM) behind /api/auth/convex-token/ and the account
# island's server-side minter. Server-only — never NEXT_PUBLIC. The single-line
# form with literal \n sequences is accepted. Generate with:
#   openssl genpkey -algorithm RSA -pkeyopt rsa_keygen_bits:2048
# The matching PUBLIC key is derived from this one and served at
# /api/auth/convex-jwks/ (no separate public env var) — point the Convex
# deployment's CONVEX_AUTH_JWKS_URL at
# https://<storefront-domain>/api/auth/convex-jwks/ (the middleware rewrites the
# tenant path; the conventional /.well-known/jwks.json default does NOT exist here).
CONVEX_AUTH_PRIVATE_KEY=
# Server-trust secret the storefront's identity-less db ConvexHttpClient presents to the
# public serverQuery/serverMutation constructors for pre-tenant reads (Shop.findByDomain in
# middleware) + cross-tenant reads. Server-only; must match the Convex deployment's value.
CONVEX_SERVER_SECRET=
NEXTAUTH_SECRET=
NEXTAUTH_COOKIE_NAME=next-auth.session-token

# Per-surface kill switch for the lane-2 account live island. Unset = live; a kill
# value (0/false/off/disabled, case-insensitive) downgrades the surface to its
# read-only snapshot without a deploy — the island never opens a Convex socket.
STOREFRONT_ACCOUNT_LIVE_ISLAND=


# Vercel Flags v4 — used for discovery endpoint auth and override decryption.
# Generate with: openssl rand -base64 32
FLAGS_SECRET=

# Vercel automation bypass token (preview deployments behind protection)
VERCEL_AUTOMATION_BYPASS_SECRET=
