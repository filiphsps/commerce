# Multi-tenant storefront — required env vars

MONGODB_URI=mongodb://localhost:27017/commerce
SERVICE_DOMAIN=landing.localhost

# Convex backend. CONVEX_URL for server-side clients, NEXT_PUBLIC_CONVEX_URL for
# the browser; CONVEX_DEPLOY_KEY authenticates `convex deploy`/codegen in CI.
CONVEX_URL=
CONVEX_DEPLOY_KEY=
NEXT_PUBLIC_CONVEX_URL=
NEXTAUTH_SECRET=
NEXTAUTH_COOKIE_NAME=next-auth.session-token

# Vercel Flags v4 — used for discovery endpoint auth and override decryption.
# Generate with: openssl rand -base64 32
FLAGS_SECRET=

# Vercel automation bypass token (preview deployments behind protection)
VERCEL_AUTOMATION_BYPASS_SECRET=
