{
    "$schema": "https://json.schemastore.org/package.json",
    "name": "@nordcom/commerce-docs",
    "version": "0.0.0",
    "private": true,
    "type": "module",
    "scripts": {
        "start": "next start",
        "predev": "pnpm gen",
        "dev": "concurrently -i -k -p name pnpm:dev:next pnpm:dev:watch",
        "dev:next": "NODE_ENV=development next dev --turbo",
        "dev:watch": "tsx scripts/watch-docs.ts",
        "prebuild": "pnpm gen",
        "build": "next build --turbo",
        "generate": "pnpm gen",
        "gen": "tsx scripts/gen.ts && fumadocs-mdx",
        "gen:check": "tsx scripts/docs-gen-check.ts",
        "clean": "rimraf -g dist coverage .turbo .next out .typedoc-out content/reference content/errors content/packages/applications *.tsbuildinfo *.log node_modules",
        "lint": "biome lint .",
        "format": "concurrently -i pnpm:format:*",
        "format:lint": "biome lint --write .",
        "format:format": "biome format --write .",
        "format:check": "biome check --write --unsafe .",
        "typegen": "next typegen",
        "typecheck": "tsc -noEmit",
        "test": "vitest run",
        "test:watch": "vitest",
        "test:e2e": "playwright test --pass-with-no-tests",
        "test:links": "tsx scripts/validate-links.ts",
        "analyze": "next experimental-analyze"
    },
    "dependencies": {
        "@nordcom/commerce-cms": "workspace:*",
        "@nordcom/commerce-db": "workspace:*",
        "@nordcom/commerce-errors": "workspace:*",
        "@nordcom/commerce-marketing-common": "workspace:*",
        "@nordcom/commerce-shopify-graphql": "workspace:*",
        "@nordcom/commerce-shopify-html": "workspace:*",
        "@nordcom/nordstar": "0.1.1",
        "@vercel/analytics": "2.0.1",
        "fumadocs-core": "16.10.2",
        "fumadocs-mdx": "15.0.12",
        "fumadocs-ui": "16.10.2",
        "geist": "1.7.2",
        "next": "16.2.9",
        "react": "19.2.7",
        "react-dom": "19.2.7"
    },
    "devDependencies": {
        "@playwright/test": "1.60.0",
        "@tailwindcss/postcss": "4.3.1",
        "@tailwindcss/typography": "0.5.20",
        "@testing-library/react": "16.3.2",
        "@types/mdx": "2.0.14",
        "@types/node": "25.9.3",
        "@types/react": "19.2.17",
        "@types/react-dom": "19.2.3",
        "concurrently": "10.0.3",
        "happy-dom": "20.10.3",
        "rimraf": "6.1.3",
        "tailwindcss": "4.3.1",
        "tsx": "4.22.4",
        "typedoc": "0.28.19",
        "typescript": "6.0.3",
        "vitest": "4.1.8"
    },
    "browserslist": {
        "production": [
            ">0.5%",
            "not dead",
            "not op_mini all"
        ],
        "development": [
            "last 3 chrome version",
            "last 3 firefox version",
            "last 5 safari version"
        ]
    }
}
