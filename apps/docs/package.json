{
    "$schema": "https://json.schemastore.org/package.json",
    "name": "@nordcom/commerce-docs",
    "version": "0.0.0",
    "private": true,
    "type": "module",
    "scripts": {
        "dev": "pnpm pre && concurrently -i -k pnpm:dev:next pnpm:dev:watch",
        "dev:next": "NODE_ENV=development next dev --turbo",
        "dev:watch": "node scripts/watch-docs.mjs",
        "pre": "pnpm pre:typedoc && pnpm pre:mirror && pnpm pre:page-map",
        "pre:typedoc": "node scripts/emit-typedoc-json.mjs",
        "pre:mirror": "node scripts/mirror-workspace-docs.mjs",
        "pre:page-map": "node scripts/generate-page-map.mjs",
        "build": "pnpm pre && next build --turbo && pnpm postbuild",
        "postbuild": "pagefind --site out --output-path \"out${NEXT_PUBLIC_DOCS_BASE_PATH:-}/_pagefind\"",
        "start": "next start -p $PORT",
        "lint": "biome lint .",
        "format": "concurrently -i pnpm:format:*",
        "format:lint": "biome lint --write .",
        "format:format": "biome format --write .",
        "format:check": "biome check --write --unsafe .",
        "typecheck": "pnpm pre:page-map && next typegen && tsc -noEmit",
        "test": "vitest run",
        "test:watch": "vitest",
        "test:e2e": "playwright test",
        "test:docs:links": "node scripts/validate-links.mjs",
        "docs:gen:check": "node scripts/docs-gen-check.mjs",
        "clean": "rimraf -g .next out .typedoc-out 'app/docs/(generated)' public/_pagefind .turbo *.tsbuildinfo *.log",
        "analyze": "next experimental-analyze"
    },
    "dependencies": {
        "@nordcom/commerce-cms": "workspace:*",
        "@nordcom/commerce-db": "workspace:*",
        "@nordcom/commerce-errors": "workspace:*",
        "@nordcom/commerce-marketing-common": "workspace:*",
        "@nordcom/commerce-shopify-graphql": "workspace:*",
        "@nordcom/commerce-shopify-html": "workspace:*",
        "@vercel/analytics": "2.0.1",
        "cmdk": "1.1.1",
        "next": "16.2.6",
        "nextra": "4.6.1",
        "nextra-theme-docs": "4.6.1",
        "react": "19.2.6",
        "react-dom": "19.2.6",
        "shiki": "3.16.0"
    },
    "devDependencies": {
        "@playwright/test": "1.60.0",
        "@tailwindcss/postcss": "4.3.0",
        "@testing-library/react": "16.3.2",
        "@types/node": "24.12.4",
        "@types/react": "19.2.14",
        "@types/react-dom": "19.2.3",
        "concurrently": "9.2.1",
        "happy-dom": "20.9.0",
        "pagefind": "1.5.2",
        "rimraf": "6.1.3",
        "serve": "14.2.6",
        "tailwindcss": "4.3.0",
        "typedoc": "0.28.19",
        "typescript": "6.0.3",
        "vitest": "4.1.6"
    },
    "browserslist": {
        "production": [
            ">0.5%",
            "not dead",
            "not op_mini all"
        ],
        "development": [
            "last 3 chrome version",
            "last 3 firefox version",
            "last 5 safari version"
        ]
    }
}
