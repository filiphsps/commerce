{
    "$schema": "https://json.schemastore.org/package.json",
    "name": "@nordcom/commerce-landing",
    "version": "2.0.0",
    "private": true,
    "sideEffects": false,
    "type": "module",
    "cacheDirectories": [
        ".next/cache"
    ],
    "scripts": {
        "start": "next start -p $PORT",
        "dev": "NODE_ENV=development next dev --turbo",
        "build": "next build --turbo",
        "clean": "rimraf -g dist coverage .turbo .next *.tsbuildinfo *.log node_modules",
        "lint": "biome lint .",
        "format": "concurrently -i pnpm:format:*",
        "format:lint": "biome lint --write .",
        "format:format": "biome format --write .",
        "format:check": "biome check --write --unsafe .",
        "typegen": "next typegen",
        "typecheck": "tsc -noEmit",
        "analyze": "next experimental-analyze",
        "test": "vitest run --coverage --passWithNoTests --maxWorkers=2 --reporter=default --reporter=junit --outputFile.junit=./junit.xml"
    },
    "author": {
        "name": "Filiph Sandström",
        "email": "filfat@hotmail.se",
        "url": "https://github.com/filiphsps/"
    },
    "contributors": [
        {
            "name": "Filiph Sandström",
            "email": "filfat@hotmail.se",
            "url": "https://github.com/filiphsps/"
        }
    ],
    "repository": {
        "type": "git",
        "url": "git+https://github.com/filiphsps/commerce.git"
    },
    "keywords": [
        "nextjs",
        "react"
    ],
    "bugs": {
        "url": "https://github.com/filiphsps/commerce/issues"
    },
    "homepage": "https://github.com/filiphsps/commerce/",
    "dependencies": {
        "@markdoc/markdoc": "0.5.7",
        "@markdoc/next.js": "0.5.0",
        "@next/third-parties": "16.2.9",
        "@nordcom/commerce-errors": "workspace:*",
        "@nordcom/commerce-marketing-common": "workspace:*",
        "@nordcom/commerce-utils": "workspace:*",
        "next-build-notifier": "workspace:*",
        "@nordcom/nordstar": "0.2.0",
        "@opentelemetry/api-logs": "0.219.0",
        "@opentelemetry/instrumentation": "0.219.0",
        "@opentelemetry/sdk-logs": "0.219.0",
        "@vercel/otel": "2.1.3",
        "clsx": "2.1.1",
        "geist": "1.7.2",
        "glob": "13.0.6",
        "gravatar.js": "2.0.0",
        "gray-matter": "4.0.3",
        "next": "16.2.9",
        "nextjs-toploader": "3.9.17",
        "nprogress": "0.2.0",
        "react": "19.2.7",
        "react-dom": "19.2.7",
        "react-icons": "5.6.0",
        "sharp": "0.35.1",
        "sonner": "2.0.7",
        "tailwind-merge": "3.6.0"
    },
    "devDependencies": {
        "@happy-dom/global-registrator": "20.10.3",
        "@tailwindcss/forms": "0.5.11",
        "@tailwindcss/postcss": "4.3.1",
        "@tailwindcss/typography": "0.5.20",
        "@testing-library/jest-dom": "6.9.1",
        "@testing-library/react": "16.3.2",
        "@types/convert-units": "2.3.12",
        "@types/node": "25.9.3",
        "@types/nprogress": "0.2.3",
        "@types/react": "19.2.17",
        "@types/react-dom": "19.2.3",
        "babel-plugin-react-compiler": "1.0.0",
        "concurrently": "10.0.3",
        "critters": "0.0.25",
        "dotenv": "17.4.2",
        "graphql": "16.14.2",
        "happy-dom": "20.10.3",
        "postcss": "8.5.15",
        "postcss-load-config": "6.0.1",
        "rimraf": "6.1.3",
        "server-only": "0.0.1",
        "tailwindcss": "4.3.1",
        "typescript": "6.0.3",
        "vitest": "4.1.8"
    }
}
