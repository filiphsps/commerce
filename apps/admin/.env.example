# Clerk — operator auth. The publishable key is browser-exposed; the secret key is server-only.
# CLERK_FRONTEND_API_URL is Clerk's Frontend API origin (dev: https://<slug>.clerk.accounts.dev) and
# is ALSO set on the Convex deployment so its native Clerk provider can validate operator tokens.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
CLERK_FRONTEND_API_URL=
# Admin sign-in/up routing. The app also wires these on <ClerkProvider>, so these are optional
# overrides; afterSignIn/Up land on `/`.
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/auth/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/auth/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/
SERVER_URL=http://localhost:3000

# Convex backend. CONVEX_URL for server-side clients, NEXT_PUBLIC_CONVEX_URL for
# the browser; CONVEX_DEPLOY_KEY authenticates `convex deploy`/codegen in CI.
CONVEX_URL=http://127.0.0.1:3210
CONVEX_DEPLOY_KEY=
NEXT_PUBLIC_CONVEX_URL=http://127.0.0.1:3210
# Operator auth tokens are now minted by Clerk (the `convex` JWT template), validated by the Convex
# deployment's native Clerk provider — no admin-side RS256 keypair. The storefront keeps its own
# CONVEX_AUTH_* customer minter; those vars belong to apps/storefront, not here.
# Server-trust secret the admin's identity-less db ConvexHttpClient presents to the public
# serverQuery/serverMutation constructors for platform-global users access. Server-only; must match
# the Convex deployment's value.
CONVEX_SERVER_SECRET=dev-local-secret
STOREFRONT_BASE_URL=https://storefront.localhost
STOREFRONT_PREVIEW_SECRET=
# Vercel domain provisioning. When VERCEL_TOKEN + VERCEL_STOREFRONT_PROJECT_ID are
# set, Settings → Domain adds each customer-facing domain to the storefront's Vercel
# project and verifies it via the Vercel API; otherwise it falls back to a
# DNS-over-HTTPS check against SERVICE_DOMAIN. VERCEL_TEAM_ID is optional (team scope).
# *.localhost domains auto-verify in dev.
VERCEL_TOKEN=
VERCEL_STOREFRONT_PROJECT_ID=
VERCEL_TEAM_ID=
S3_ENDPOINT=
S3_BUCKET=
S3_REGION=auto
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=

# OAuth connections (GitHub, Google, …) are configured on the Clerk instance, not via app env vars —
# the dev instance uses Clerk's shared dev OAuth, so no provider client id/secret is needed locally.

# Vercel Flags v4 — share the same value with apps/storefront/.env if you want
# the toolbar to operate on both apps.
FLAGS_SECRET=
