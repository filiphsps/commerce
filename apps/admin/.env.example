NEXTAUTH_SECRET=
NEXTAUTH_COOKIE_NAME=next-auth.session-token
SERVER_URL=http://localhost:3000

# Convex backend. CONVEX_URL for server-side clients, NEXT_PUBLIC_CONVEX_URL for
# the browser; CONVEX_DEPLOY_KEY authenticates `convex deploy`/codegen in CI.
CONVEX_URL=http://127.0.0.1:3210
CONVEX_DEPLOY_KEY=
NEXT_PUBLIC_CONVEX_URL=http://127.0.0.1:3210
# Convex auth — admin mints the NextAuth-derived RS256 JWT the Convex deployment
# validates and serves the JWKS at CONVEX_AUTH_JWKS_URL. CONVEX_AUTH_ISSUER =
# `iss` claim (this admin origin), CONVEX_AUTH_APPLICATION_ID = `aud` claim;
# CONVEX_AUTH_JWKS_URL defaults to ${CONVEX_AUTH_ISSUER}/.well-known/jwks.json.
CONVEX_AUTH_ISSUER=
CONVEX_AUTH_APPLICATION_ID=
CONVEX_AUTH_JWKS_URL=
# RS256 signing key (PKCS8 PEM) behind the admin operator token minter
# (src/lib/convex-token.ts). Server-only; shares the storefront's key so both
# apps sign against the same JWKS. Single-line form with literal \n accepted.
# Generate with: openssl genpkey -algorithm RSA -pkeyopt rsa_keygen_bits:2048
CONVEX_AUTH_PRIVATE_KEY=
# Server-trust secret the admin's identity-less db ConvexHttpClient presents to the public
# serverQuery/serverMutation constructors for the Auth.js adapter's platform-global
# users/sessions/identities access. Server-only; must match the Convex deployment's value.
CONVEX_SERVER_SECRET=dev-local-secret
STOREFRONT_BASE_URL=https://storefront.localhost
STOREFRONT_PREVIEW_SECRET=
# Vercel domain provisioning. When VERCEL_TOKEN + VERCEL_STOREFRONT_PROJECT_ID are
# set, Settings → Domain adds each customer-facing domain to the storefront's Vercel
# project and verifies it via the Vercel API; otherwise it falls back to a
# DNS-over-HTTPS check against SERVICE_DOMAIN. VERCEL_TEAM_ID is optional (team scope).
# *.localhost domains auto-verify in dev.
VERCEL_TOKEN=
VERCEL_STOREFRONT_PROJECT_ID=
VERCEL_TEAM_ID=
S3_ENDPOINT=
S3_BUCKET=
S3_REGION=auto
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
GITHUB_ID=
GITHUB_TOKEN=

# Auth.js redirect proxy for preview deploys. GitHub OAuth permits one fixed callback host, but
# preview deploys live on per-build `*.vercel.app` URLs. Set this to the STABLE production admin's
# Auth.js path (e.g. `https://admin.example.com/api/auth`) on BOTH the Production and Preview Vercel
# environments — the proxy only activates when production also has it, and both sides must share
# NEXTAUTH_SECRET/AUTH_SECRET so the encrypted `state` round-trips. Register that same URL's
# `/callback/github` as the GitHub OAuth app callback. Leave empty locally.
# NOTE: do NOT set AUTH_URL to the production URL on the Preview environment, or Auth.js will
# mis-base the preview's own routes — leave AUTH_URL unset on Preview and rely on the trusted host.
AUTH_REDIRECT_PROXY_URL=

# Vercel Flags v4 — share the same value with apps/storefront/.env if you want
# the toolbar to operate on both apps.
FLAGS_SECRET=
