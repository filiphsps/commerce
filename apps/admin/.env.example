NEXTAUTH_SECRET=
NEXTAUTH_COOKIE_NAME=next-auth.session-token
MONGODB_URI=mongodb://localhost:27017/commerce
SERVER_URL=http://localhost:3000

# Convex backend. CONVEX_URL for server-side clients, NEXT_PUBLIC_CONVEX_URL for
# the browser; CONVEX_DEPLOY_KEY authenticates `convex deploy`/codegen in CI.
CONVEX_URL=
CONVEX_DEPLOY_KEY=
NEXT_PUBLIC_CONVEX_URL=
# Convex auth — admin mints the NextAuth-derived RS256 JWT the Convex deployment
# validates and serves the JWKS at CONVEX_AUTH_JWKS_URL. CONVEX_AUTH_ISSUER =
# `iss` claim (this admin origin), CONVEX_AUTH_APPLICATION_ID = `aud` claim;
# CONVEX_AUTH_JWKS_URL defaults to ${CONVEX_AUTH_ISSUER}/.well-known/jwks.json.
CONVEX_AUTH_ISSUER=
CONVEX_AUTH_APPLICATION_ID=
CONVEX_AUTH_JWKS_URL=
# RS256 signing key (PKCS8 PEM) behind the admin operator token minter
# (src/lib/convex-token.ts). Server-only; shares the storefront's key so both
# apps sign against the same JWKS. Single-line form with literal \n accepted.
# Generate with: openssl genpkey -algorithm RSA -pkeyopt rsa_keygen_bits:2048
CONVEX_AUTH_PRIVATE_KEY=
# Server-trust secret the admin's identity-less db ConvexHttpClient presents to the public
# serverQuery/serverMutation constructors for the Auth.js adapter's platform-global
# users/sessions/identities access. Server-only; must match the Convex deployment's value.
CONVEX_SERVER_SECRET=
STOREFRONT_BASE_URL=https://storefront.localhost
STOREFRONT_PREVIEW_SECRET=
S3_ENDPOINT=
S3_BUCKET=
S3_REGION=auto
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
GITHUB_ID=
GITHUB_TOKEN=

# Vercel Flags v4 — share the same value with apps/storefront/.env if you want
# the toolbar to operate on both apps.
FLAGS_SECRET=
