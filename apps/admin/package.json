{
    "$schema": "https://json.schemastore.org/package.json",
    "name": "@nordcom/commerce-admin",
    "version": "2.0.0",
    "private": true,
    "sideEffects": false,
    "type": "module",
    "cacheDirectories": [
        ".next/cache"
    ],
    "scripts": {
        "start": "next start",
        "dev": "NODE_ENV=development next dev --turbo",
        "build": "next build --turbo",
        "clean": "rimraf -g dist coverage .turbo .next *.tsbuildinfo *.log node_modules",
        "lint": "biome lint .",
        "format": "concurrently -i pnpm:format:*",
        "format:lint": "biome lint --write .",
        "format:format": "biome format --write .",
        "format:check": "biome check --write --unsafe .",
        "test:e2e": "playwright test",
        "generate": "pnpm --filter @nordcom/commerce-cms cms:gen",
        "typegen": "next typegen",
        "typecheck": "tsc -noEmit",
        "analyze": "next experimental-analyze"
    },
    "author": {
        "name": "Filiph Sandström",
        "email": "filfat@hotmail.se",
        "url": "https://github.com/filiphsps/"
    },
    "contributors": [
        {
            "name": "Filiph Sandström",
            "email": "filfat@hotmail.se",
            "url": "https://github.com/filiphsps/"
        }
    ],
    "repository": {
        "type": "git",
        "url": "git+https://github.com/filiphsps/commerce.git"
    },
    "keywords": [
        "nextjs",
        "react"
    ],
    "bugs": {
        "url": "https://github.com/filiphsps/commerce/issues"
    },
    "homepage": "https://github.com/filiphsps/commerce/",
    "dependencies": {
        "@auth/core": "0.41.2",
        "@faceless-ui/modal": "3.0.0",
        "@floating-ui/react": "0.27.19",
        "@next/third-parties": "16.2.6",
        "@nordcom/commerce-cms": "workspace:*",
        "@nordcom/commerce-db": "workspace:*",
        "@nordcom/commerce-errors": "workspace:*",
        "@nordcom/commerce-marketing-common": "workspace:*",
        "@nordcom/commerce-utils": "workspace:*",
        "@nordcom/nordstar": "0.0.75",
        "@opentelemetry/api-logs": "0.218.0",
        "@opentelemetry/instrumentation": "0.218.0",
        "@opentelemetry/sdk-logs": "0.218.0",
        "@payloadcms/db-mongodb": "3.85.0",
