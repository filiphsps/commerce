{
    "$schema": "https://json.schemastore.org/package.json",
    "name": "@nordcom/commerce-admin",
    "version": "2.0.0",
    "private": true,
    "sideEffects": false,
    "type": "module",
    "cacheDirectories": [
        ".next/cache"
    ],
    "scripts": {
        "start": "next start -p $PORT",
        "dev": "next dev -p 3000",
        "build": "next build --turbo",
        "clean": "rimraf -g dist coverage .turbo .next *.tsbuildinfo *.log node_modules",
        "lint": "biome lint .",
        "format": "concurrently -i pnpm:format:*",
        "format:lint": "biome lint --write .",
        "format:format": "biome format --write .",
        "format:check": "biome check --write --unsafe .",
        "test:e2e": "playwright test",
        "typecheck": "tsc -noEmit",
        "slicemachine": "exit 0"
    },
    "author": {
        "name": "Nordcom AB",
        "email": "hi@nordcom.io",
        "url": "https://nordcom.io/"
    },
    "contributors": [
        {
            "name": "Filiph Siitam Sandström",
            "email": "filiph@nordcom.io",
            "url": "https://github.com/filiphsps/"
        }
    ],
    "repository": {
        "type": "git",
        "url": "git+https://github.com/filiphsps/commerce.git"
    },
    "keywords": [
        "nextjs",
        "react"
    ],
    "bugs": {
        "url": "https://github.com/filiphsps/commerce/issues"
    },
    "homepage": "https://shops.nordcom.io/",
    "dependencies": {
        "@auth/core": "0.37.3",
        "@next/third-parties": "16.2.4",
        "@nordcom/commerce-db": "workspace:*",
        "@nordcom/commerce-errors": "workspace:*",
        "@nordcom/commerce-marketing-common": "workspace:*",
        "@nordcom/nordstar": "0.0.74",
        "@opentelemetry/api-logs": "0.216.0",
        "@opentelemetry/instrumentation": "0.216.0",
        "@opentelemetry/sdk-logs": "0.216.0",
        "@radix-ui/react-avatar": "1.1.11",
        "@radix-ui/react-scroll-area": "1.2.10",
        "@shopify/shopify-api": "11.6.0",
        "@vercel/otel": "2.1.2",
        "@vercel/toolbar": "0.2.2",
        "clsx": "2.1.1",
        "geist": "1.7.0",
        "lucide-react": "1.14.0",
        "next": "16.2.4",
        "next-auth": "5.0.0-beta.31",
        "nextjs-toploader": "3.9.17",
        "nprogress": "0.2.0",
        "react": "19.2.5",
        "react-dom": "19.2.5",
        "sharp": "0.34.5",
        "sonner": "2.0.7",
        "tailwind-merge": "3.6.0"
    },
    "devDependencies": {
        "@happy-dom/global-registrator": "20.9.0",
        "@playwright/test": "1.60.0",
        "@tailwindcss/forms": "0.5.9",
        "@tailwindcss/postcss": "4.2.2",
        "@tailwindcss/typography": "0.5.15",
        "@testing-library/jest-dom": "6.9.1",
        "@testing-library/react": "16.0.1",
        "@types/node": "22.8.6",
        "@types/nprogress": "0.2.3",
        "@types/react": "19.2.14",
        "@types/react-dom": "19.2.3",
        "babel-plugin-react-compiler": "1.0.0",
        "concurrently": "9.2.1",
        "critters": "0.0.25",
        "dotenv": "17.4.2",
        "graphql": "16.9.0",
        "happy-dom": "20.9.0",
        "postcss": "8.5.14",
        "postcss-load-config": "6.0.1",
        "rimraf": "6.1.3",
        "server-only": "0.0.1",
        "tailwindcss": "4.2.2",
        "typescript": "6.0.3",
        "vitest": "4.1.5"
    }
}
