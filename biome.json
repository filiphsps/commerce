{
    "$schema": "https://biomejs.dev/schemas/2.4.15/schema.json",
    "assist": {
        "actions": {
            "source": {
                "organizeImports": "on"
            }
        },
        "includes": ["**", "!package.json", "!coverage/**", "!**/coverage/**", "!.claude/**", "!docs/superpowers/**"]
    },
    "css": {
        "formatter": { "enabled": true },
        "linter": { "enabled": true },
        "parser": { "cssModules": true, "tailwindDirectives": true }
    },
    "files": {
        "includes": [
            "**",
            "!**/*.d.ts",
            "!**/*.scss",
            "!**/.claude",
            "!**/.specs",
            "!**/public/robots.txt*",
            "!**/public/sitemap*.xml*",
            "!**/storybook-static",
            "!docs/superpowers",
            "!packages/cms/src/types/content-types.ts",
            "!packages/convex/convex/__fixtures__",
            "!packages/convex/convex/_generated",
            "!packages/convex/convex/tables/cms.ts",
            "!packages/convex/convex/tsconfig.json",
            "!packages/shopify-graphql/storefront.schema.json"
        ]
    },
    "formatter": {
        "enabled": true,
        "includes": ["**"],
        "indentStyle": "space",
        "indentWidth": 4,
        "lineEnding": "lf",
        "lineWidth": 120
    },
    "javascript": {
        "formatter": {
            "arrowParentheses": "always",
            "bracketSpacing": true,
            "quoteStyle": "single",
            "semicolons": "always",
            "trailingCommas": "all"
        },
        "jsxRuntime": "transparent"
    },
    "linter": {
        "enabled": true,
        "includes": ["**", "!package.json"],
        "rules": {
            "recommended": true,
            "a11y": { "recommended": false },
            "complexity": {
                "noBannedTypes": "off",
                "useArrowFunction": "off"
            },
            "correctness": {
                "noChildrenProp": "warn",
                "noEmptyPattern": "off",
                "noUnusedImports": "error",
                "noUnusedVariables": { "fix": "unsafe", "level": "error" },
                "useExhaustiveDependencies": "warn",
                "useHookAtTopLevel": "error"
            },
            "nursery": {
                "useSortedClasses": { "fix": "unsafe", "level": "warn" }
            },
            "performance": {
                "noNamespaceImport": "off",
                "recommended": true
            },
            "security": {
                "noDangerouslySetInnerHtml": "off"
            },
            "style": {
                "noNonNullAssertion": "off",
                "noRestrictedImports": {
                    "level": "error",
                    "options": {
                        "paths": {
                            "./_generated/server": {
                                "message": "Import a tenant/system constructor from the `@nordcom/commerce-convex` `_constructors` barrel (tenantQuery, tenantMutation, systemQuery, systemMutation) instead of the raw, RLS-bypassing builders in `_generated/server`.",
                                "importNames": ["query", "mutation", "internalQuery"]
                            },
                            "../_generated/server": {
                                "message": "Import a tenant/system constructor from the `@nordcom/commerce-convex` `_constructors` barrel (tenantQuery, tenantMutation, systemQuery, systemMutation) instead of the raw, RLS-bypassing builders in `_generated/server`.",
                                "importNames": ["query", "mutation", "internalQuery"]
                            }
                        }
                    }
                },
                "useConst": "error",
                "useFilenamingConvention": "off",
                "useImportType": "error",
                "useNamingConvention": "off"
            },
            "suspicious": {
                "noArrayIndexKey": "off",
                "noAssignInExpressions": "warn",
                "noAsyncPromiseExecutor": "warn",
                "noConsole": {
                    "level": "warn",
                    "options": { "allow": ["warn", "error", "info", "debug"] }
                },
                "noDebugger": "warn",
                "noDocumentCookie": "off",
                "noEmptyInterface": "off",
                "noExplicitAny": "warn",
                "noNonNullAssertedOptionalChain": "warn",
                "noShadowRestrictedNames": "off",
                "noVar": "error"
            }
        }
    },
    "overrides": [
        {
            "includes": [
                "packages/convex/convex/lib/tenant.ts",
                "packages/convex/convex/lib/authed.ts",
                "packages/convex/convex/lib/system.ts",
                "packages/convex/convex/lib/rls.ts",
                "packages/convex/convex/lib/server.ts"
            ],
            "linter": {
                "rules": {
                    "style": {
                        "noRestrictedImports": "off"
                    }
                }
            }
        },
        {
            "includes": ["**/*.test.*", "**/*.spec.*", "**/vitest.config.*", "**/vitest.setup.*"],
            "linter": {
                "rules": {
                    "performance": { "useTopLevelRegex": "off" },
                    "suspicious": {
                        "noConsole": "off",
                        "noExplicitAny": "off",
                        "noVar": "off"
                    }
                }
            }
        },
        {
            "includes": [
                "**/next.config.*",
                "**/postcss.config.*",
                "**/tailwind.config.*",
                "**/instrumentation.ts",
                "**/data-cache-handler.mjs"
            ],
            "linter": {
                "rules": {
                    "suspicious": {
                        "noConsole": "off",
                        "noExplicitAny": "off"
                    }
                }
            }
        }
    ],
    "vcs": {
        "clientKind": "git",
        "enabled": true,
        "useIgnoreFile": true
    }
}
