{
    "$schema": "https://turbo.build/schema.json",
    "ui": "stream",
    "globalDependencies": [
        "**/.env.*local",
        "tsconfig.json",
        "**/tsconfig.json",
        "vite.config.ts",
        "**/vite.config.ts",
        "package.json",
        "**/package.json",
        "biome.json",
        ".env",
        "**/.env",
        "*.env",
        "**/*.env"
    ],
    "globalPassThroughEnv": ["NODE_ENV"],
    "tasks": {
        "build": {
            "cache": true,
            "outputLogs": "new-only",
            "dependsOn": ["^build"],
            "outputs": [".next/**", "!.next/cache/**", "dist/**", "build/**", "api/**", ".docusaurus/**"],
            "inputs": [
                "$TURBO_DEFAULT$",
                "!README.md",
                ".env.production.local",
                ".env.local",
                ".env.production",
                ".env"
            ]
        },
        "clean": {
            "cache": false
        },
        "dev": {
            "cache": false,
            "persistent": true,
            "inputs": ["$TURBO_DEFAULT$", ".env.development.local", ".env.local", ".env.development", ".env"]
        },
        "lint": {
            "cache": true,
            "dependsOn": ["^build"],
            "outputs": []
        },
        "typecheck": {
            "cache": false,
            "dependsOn": ["^build"]
        },
        "format": {
            "cache": false
        },
        "format:lint": {
            "cache": false
        },
        "format:format": {
            "cache": false
        },
        "format:check": {
            "cache": false
        },
        "test:e2e": {
            "cache": false,
            "dependsOn": ["^build"],
            "outputs": ["playwright-report/**", "test-results/**"]
        },
        "generate:types": {
            "cache": true
        }
    }
}
