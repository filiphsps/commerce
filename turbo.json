{
    "$schema": "https://turborepo.dev/schema.json",
    "ui": "stream",
    "globalPassThroughEnv": ["NODE_ENV"],
    "globalDependencies": [
        "package.json",
        "**/package.json",
        "**/tsconfig.json",
        "pnpm-lock.yaml",
        "pnpm-workspace.yaml",
        "!CHANGELOG.md",
        "!*.md"
    ],
    "tasks": {
        "build": {
            "cache": true,
            "dependsOn": ["^generate", "^build"],
            "outputs": [
                ".next/**",
                "!.next/cache/**",
                "dist/**",
                "build/**",
                "out/**",
                "api/**",
                ".typedoc-out/**",
                "public/_pagefind/**"
            ],
            "outputLogs": "new-only"
        },
        "generate": {
            "cache": true,
            "persistent": false,
            "dependsOn": ["^generate"],
            "outputs": ["src/generated/**", "src/graphql-env.d.ts", "storefront.schema.json"],
            "outputLogs": "new-only"
        },
        "build:packages": {
            "cache": true,
            "dependsOn": ["^generate", "^build:packages"],
            "outputs": ["dist/**"],
            "outputLogs": "new-only"
        },
        "start": {
            "cache": false,
            "persistent": true,
            "dependsOn": ["build"]
        },
        "dev": {
            "cache": false,
            "persistent": true
        },
        "lint": {
            "outputs": [],
            "outputLogs": "new-only"
        },
        "typegen": {
            "cache": true,
            "outputs": ["next-env.d.ts", ".next/types/**", ".next/dev/types/**", "lib/page-map.generated.ts"],
            "outputLogs": "new-only"
        },
        "typecheck": {
            "dependsOn": ["typegen"],
            "outputLogs": "new-only"
        },
        "format": {
            "cache": false
        },
        "format:lint": {
            "cache": false
        },
        "format:format": {
            "cache": false
        },
        "format:check": {
            "cache": false
        },
        "test": {
            "dependsOn": ["^build:packages"],
            "outputs": ["coverage/**"],
            "outputLogs": "new-only"
        },
        "test:watch": {
            "cache": false,
            "persistent": true
        },
        "test:e2e": {
            "cache": false,
            "dependsOn": ["^build", "build"],
            "outputs": ["playwright-report/**", "test-results/**"]
        },
        "clean": {
            "cache": false
        },
        "analyze": {
            "cache": false,
            "persistent": true,
            "dependsOn": ["^build"]
        }
    }
}
