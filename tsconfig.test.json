{
    "$schema": "https://json.schemastore.org/tsconfig",
    "compilerOptions": {
        "allowSyntheticDefaultImports": true,
        "composite": true,
        "jsx": "react-jsx",
        "types": ["node", "vitest/globals", "happy-dom"]
    },

    "exclude": ["**/.turbo", "**/coverage", "**/*.stories.ts", "**/dist", "node_modules"],
    "include": ["./apps/**/*.test.*", "./packages/**/*.test.*", "./apps/**/vite*", "./packages/**/vite*"],
    "references": [{ "path": "./tsconfig.node.json" }]
}
