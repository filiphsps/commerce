# ====================================================================================
# Nordcom Commerce - Environment Variables
# ====================================================================================
# Example .env file for local development.
# Copy this file to .env and fill in the values.
#
# Note: the `.env` file is ignored by git.
# Contact Filiph Sandström <filfat@hotmail.se> if you need help.
# ====================================================================================
SERVICE_DOMAIN=shops.nordcom.io
# Hostname for the admin dashboard (e.g. admin.example.com). Used to build absolute
# URLs (manifest scope, metadataBase, Shopify embed host). Falls back to localhost:3000.
ADMIN_DOMAIN=
# Hostname for the marketing / landing site (e.g. example.com). Used by the admin
# for assets such as the logo and post sign-in redirects. Falls back to localhost:3001.
LANDING_DOMAIN=

# Database. ==========================================================================
MONGODB_URI=
# Optional. Overrides MONGODB_URI for the test suite. Falls back to
# mongodb://localhost:27017/test if neither is set. Use this in CI when you have
# a dedicated test cluster, or locally when you want to point tests at a
# different DB than your dev data.
MONGODB_URI_TEST=

# Authentication. ====================================================================
AUTH_SECRET=
# Required, See github.com/nextauthjs/next-auth/issues/600#issuecomment-1784736042
AUTH_TRUST_HOST=true
# Optional separate secret for the NextAuth -> Payload auth bridge. Defaults to
# AUTH_SECRET if unset. If set, must match the secret NextAuth signs JWTs with.
NEXTAUTH_SECRET=
# ====================================================================================

# CMS (@nordcom/commerce-cms / Payload). =============================================
# Required. Used by Payload to sign its own session/preview cookies. Generate
# with `openssl rand -hex 32`. Independent from AUTH_SECRET so the two systems
# can be rotated separately.
PAYLOAD_SECRET=
# Public base URL of the storefront, used by the admin's live-preview iframe
# to build preview URLs (e.g. https://storefront.example). Defaults to
# http://localhost:1337 if unset.
STOREFRONT_BASE_URL=
# Required for the storefront's /[domain]/api/cms-preview route. The admin's
# "preview" button sends ?secret=<value> here to flip Next.js draft mode on.
# Generate with `openssl rand -hex 32`.
STOREFRONT_PREVIEW_SECRET=

# Optional S3 storage for CMS media uploads. Storage plugin is skipped if any
# of these are unset. Local development can leave them empty (uploads land in
# Payload's default disk storage).
S3_BUCKET=
S3_ENDPOINT=
S3_REGION=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=

# Services. ==========================================================================
GITHUB_ID=
GITHUB_TOKEN=
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET_KEY=
# HMAC secret for validating Shopify webhook authenticity. Required in production.
SHOPIFY_WEBHOOK_SECRET=

# Logging. ===========================================================================


# Coverage. ==========================================================================
CODECOV_TOKEN=

# Remote Cache. ======================================================================
# Turborepo Remote Cache (Vercel-hosted). Share build/test cache between local dev and
# CI runners. Create a token at https://vercel.com/account/tokens.
TURBO_TOKEN=
# Vercel team/account slug that owns the Remote Cache. Must match the account that
# issued TURBO_TOKEN.
TURBO_TEAM=

# Misc. ==============================================================================
VERCEL_AUTOMATION_BYPASS_SECRET=
